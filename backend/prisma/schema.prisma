generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles, permissions and users.
model Role {
  id          String           @id @default(uuid())
  slug        RoleSlug         @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int              @default(1)
  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  action      PermissionAction
  resource    String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int              @default(1)
  roles       RolePermission[]

  @@unique([action, resource])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  syncedAt     DateTime?
  sourceNode   String?
  version      Int        @default(1)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id                               String                     @id @default(uuid())
  email                            String                     @unique
  username                         String                     @unique
  displayName                      String
  firstName                        String
  lastName                         String
  passwordHash                     String
  status                           UserStatus                 @default(ACTIVE)
  primaryRole                      RoleSlug?
  specialty                        String?
  bio                              String?
  profilePhotoUrl                  String?
  phone                            String?
  whatsappUrl                      String?
  facebookUrl                      String?
  instagramUrl                     String?
  linkedinUrl                      String?
  nationality                      String?
  addressCountry                   String?
  addressProvince                  String?
  addressCity                      String?
  addressNeighborhood              String?
  addressStreet                    String?
  lastLoginAt                      DateTime?
  preferredLanguage                String?                    @default("fr")
  createdAt                        DateTime                   @default(now())
  updatedAt                        DateTime                   @updatedAt
  deletedAt                        DateTime?
  syncedAt                         DateTime?
  sourceNode                       String?
  version                          Int                        @default(1)
  clinicId                         String?
  clinic                           Clinic?                    @relation(fields: [clinicId], references: [id])
  appointmentsRequested            Appointment[]              @relation("AppointmentRequester")
  auditLogs                        AuditLog[]
  providedConsultations            Consultation[]             @relation("ConsultationProvider")
  consultationNotesAuthored        ConsultationNote[]         @relation("ConsultationNoteAuthor")
  hospitalizationsAsNurse          Hospitalization[]          @relation("HospitalizationNurse")
  hospitalizationsAsPhysician      Hospitalization[]          @relation("HospitalizationPhysician")
  imagingReportsInterpreted        ImagingReport[]            @relation("ImagingReportInterpreter")
  imagingRequestsRequested         ImagingRequest[]           @relation("ImagingRequestRequester")
  invoicesIssued                   Invoice[]                  @relation("InvoiceIssuer")
  labRequestsRequested             LabRequest[]               @relation("LabRequestRequester")
  labResultsReported               LabResult[]                @relation("LabResultReporter")
  labRequestItemsAssigned          LabRequestItem[]           @relation("LabRequestItemAssignedTo")
  labSamplesCollected              LabSample[]                @relation("LabSampleCollectedBy")
  labSampleTrackingEventsPerformed LabSampleTrackingEvent[]   @relation("LabSampleTrackingPerformedBy")
  labRequestEventsPerformed        LabRequestEvent[]          @relation("LabRequestEventPerformedBy")
  labResultTechnicalValidated      LabResult[]                @relation("LabResultTechnicalValidator")
  labResultBiologicalValidated     LabResult[]                @relation("LabResultBiologicalValidator")
  labReportsIssued                 LabReport[]                @relation("LabReportIssuedBy")
  labConsumableStockUpdates        LabConsumableStock[]       @relation("LabConsumableStockUpdatedBy")
  labConsumableTransactions        LabConsumableTransaction[] @relation("LabConsumableTransactionPerformedBy")
  labTestsCreated                  LabTest[]                  @relation("LabTestCreatedBy")
  labTestsUpdated                  LabTest[]                  @relation("LabTestUpdatedBy")
  labSectionStaff                  LabSectionStaff[]
  medicalHistoriesCreated          MedicalHistory[]           @relation("MedicalHistoryCreatedBy")
  notificationsSent                Notification[]             @relation("NotificationAuthor")
  notifications                    Notification[]             @relation("NotificationRecipient")
  sentChatMessages                 ChatMessage[]              @relation("ChatMessageSender")
  receivedChatMessages             ChatMessage[]              @relation("ChatMessageRecipient")
  registeredPatients               Patient[]                  @relation("PatientReceptionist")
  paymentsMade                     Payment[]                  @relation("PaymentPayer")
  pharmacyDispenses                PharmacyDispense[]         @relation("PharmacyDispenseDispenser")
  prescriptionsPrescribed          Prescription[]             @relation("PrescriptionPrescriber")
  refreshTokens                    RefreshToken[]
  serviceResponsabilites           ServiceResponsable[]
  staff                            ServiceStaff[]
  surgeriesAsAnesthesiologist      Surgery[]                  @relation("SurgeryAnesthesiologist")
  surgeriesAsSurgeon               Surgery[]                  @relation("SurgerySurgeon")
  roles                            UserRole[]
  vitalSignsRecorded               VitalSign[]                @relation("VitalSignRecordedBy")
  Diagnosis                        Diagnosis[]
  ProblemList                      ProblemList[]
  Allergy                          Allergy[]
  Vaccination                      Vaccination[]
  ClinicalCondition                ClinicalCondition[]
  InsuranceClaim                   InsuranceClaim[]
  InsuranceAuthorization           InsuranceAuthorization[]
  GoodsReceipt                     GoodsReceipt[]
  StockTransaction                 StockTransaction[]
  Employee                         Employee[]
  LeaveRequest                     LeaveRequest[]
  Payroll                          Payroll[]
  AuditTrail                       AuditTrail[]
  PasswordHistory                  PasswordHistory[]
  LoginAttempt                     LoginAttempt[]
  Session                          Session[]
  PasswordResetToken               PasswordResetToken[]
  departmentResponsibilities       DepartmentResponsable[]

  @@index([primaryRole])
  @@index([clinicId])
}

model UserRole {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  active     Boolean   @default(true)
  assignedAt DateTime  @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Department {
  id                        String                  @id @default(uuid())
  name                      String                  @unique
  type                      DepartmentType
  code                      String                  @unique
  description               String?
  isParamedical             Boolean                 @default(false)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  deletedAt                 DateTime?
  syncedAt                  DateTime?
  sourceNode                String?
  version                   Int                     @default(1)
  clinicId                  String?
  clinic                    Clinic?                 @relation(fields: [clinicId], references: [id])
  services                  ServiceUnit[]
  Employee                  Employee[]
  departmentResponsabilites DepartmentResponsable[]

  @@index([clinicId])
}

model ServiceUnit {
  id               String            @id @default(uuid())
  name             String
  departmentId     String
  clinicId         String?
  clinic           Clinic?           @relation(fields: [clinicId], references: [id])
  location         String?
  contactNumber    String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  syncedAt         DateTime?
  sourceNode       String?
  version          Int               @default(1)
  appointments     Appointment[]
  hospitalizations Hospitalization[]
  rooms            Room[]
  department       Department        @relation(fields: [departmentId], references: [id])
  Employee         Employee[]

  @@unique([departmentId, name])
  @@index([clinicId])
}

/// Central services catalog (e.g. Cardiologie, Radiologie)
model Service {
  id            String               @id @default(uuid())
  name          String               @unique
  description   String?
  active        Boolean              @default(true)
  isParamedical Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  syncedAt      DateTime?
  sourceNode    String?
  version       Int                  @default(1)
  clinicId      String?
  clinic        Clinic?              @relation(fields: [clinicId], references: [id])
  patients      Patient[]
  responsables  ServiceResponsable[]
  staff         ServiceStaff[]
  tarifs        ServiceTarif[]

  @@index([clinicId])
}

/// DepartmentResponsable links departments to users (department chiefs)
model DepartmentResponsable {
  id           String    @id @default(uuid())
  departmentId String
  userId       String
  principal    Boolean   @default(false)
  actif        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  syncedAt     DateTime?
  sourceNode   String?
  version      Int       @default(1)

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
}

/// ServiceTarif allows historisation of service prices
model ServiceTarif {
  id         String    @id @default(uuid())
  serviceId  String
  prix       Decimal   @db.Decimal(12, 2)
  dateDebut  DateTime  @default(now())
  dateFin    DateTime?
  actif      Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model AdmissionFee {
  id         String    @id @default(uuid())
  label      String    @default("Frais de fiche d'admission")
  amount     Decimal   @db.Decimal(12, 2)
  currency   String    @default("USD")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
}

model ServiceStaff {
  id            String    @id @default(uuid())
  serviceId     String
  userId        String
  roleInService String?
  actif         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  syncedAt      DateTime?
  sourceNode    String?
  version       Int       @default(1)
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serviceId, userId])
}

/// ServiceResponsable links services to users (physicians)
model ServiceResponsable {
  id         String    @id @default(uuid())
  serviceId  String
  userId     String
  principal  Boolean   @default(false)
  actif      Boolean   @default(true)
  createdAt  DateTime  @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Patients and clinical records.
model Patient {
  id                     String                   @id @default(uuid())
  firstName              String
  lastName               String
  middleName             String?
  gender                 String
  profession             String?
  dateOfBirth            DateTime
  externalId             String?                  @unique
  phone                  String?
  email                  String?                  @unique
  address                String?
  city                   String?
  postalCode             String?
  nationality            String?
  bloodType              String?
  emergencyContact       String?
  emergencyPhone         String?
  insuranceProvider      String?
  insuranceNumber        String?
  status                 String                   @default("ACTIVE")
  workflowStatus         PatientWorkflowStatus    @default(EN_ATTENTE_DE_PAIEMENT)
  admissionType          String?
  priority               String?
  arrivalAt              DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  deletedAt              DateTime?
  receptionistId         String?
  serviceId              String?
  syncedAt               DateTime?
  sourceNode             String?
  version                Int                      @default(1)
  clinicId               String?
  clinic                 Clinic?                  @relation(fields: [clinicId], references: [id])
  appointments           Appointment[]
  auditLogs              AuditLog[]
  consultations          Consultation[]
  hospitalizations       Hospitalization[]
  imagingRequests        ImagingRequest[]
  invoices               Invoice[]
  labRequests            LabRequest[]
  medicalHistories       MedicalHistory[]
  notifications          Notification[]
  receptionist           User?                    @relation("PatientReceptionist", fields: [receptionistId], references: [id])
  service                Service?                 @relation(fields: [serviceId], references: [id])
  familyContacts         PatientContact[]
  prescriptions          Prescription[]
  surgeries              Surgery[]
  vitalSigns             VitalSign[]
  Diagnosis              Diagnosis[]
  ProblemList            ProblemList[]
  Allergy                Allergy[]
  Vaccination            Vaccination[]
  ClinicalCondition      ClinicalCondition[]
  InsurancePolicy        InsurancePolicy[]
  InsuranceClaim         InsuranceClaim[]
  InsuranceAuthorization InsuranceAuthorization[]

  @@index([lastName, firstName])
  @@index([dateOfBirth])
  @@index([clinicId])
}

model PatientContact {
  id           String    @id @default(uuid())
  patientId    String
  name         String
  relationship String?
  phone        String?
  email        String?
  address      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  syncedAt     DateTime?
  sourceNode   String?
  version      Int       @default(1)
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Room {
  id            String      @id @default(uuid())
  number        String      @unique
  serviceUnitId String
  status        RoomStatus  @default(AVAILABLE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  syncedAt      DateTime?
  sourceNode    String?
  version       Int         @default(1)
  beds          Bed[]
  serviceUnit   ServiceUnit @relation(fields: [serviceUnitId], references: [id])
}

model Bed {
  id                String           @id @default(uuid())
  roomId            String
  code              String
  status            BedStatus        @default(FREE)
  hospitalizationId String?          @unique
  createdAt         DateTime         @default(now())
  syncedAt          DateTime?
  sourceNode        String?
  version           Int              @default(1)
  hospitalization   Hospitalization? @relation("HospitalizationBed", fields: [hospitalizationId], references: [id])
  room              Room             @relation(fields: [roomId], references: [id])
}

model MedicalHistory {
  id          String    @id @default(uuid())
  patientId   String
  eventDate   DateTime  @default(now())
  kind        String
  details     String
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int       @default(1)
  createdBy   User?     @relation("MedicalHistoryCreatedBy", fields: [createdById], references: [id])
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

/// Appointments and scheduling.
model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  requestedById   String?
  serviceUnitId   String?
  clinicId        String?
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  reason          String?
  status          AppointmentStatus @default(SCHEDULED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  syncedAt        DateTime?
  sourceNode      String?
  version         Int               @default(1)
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requestedBy     User?             @relation("AppointmentRequester", fields: [requestedById], references: [id])
  serviceUnit     ServiceUnit?      @relation(fields: [serviceUnitId], references: [id])
  consultation    Consultation?     @relation("AppointmentConsultation")

  @@index([scheduledAt])
  @@index([status])
  @@index([clinicId])
}

model Hospitalization {
  id              String                @id @default(uuid())
  patientId       String
  serviceUnitId   String?
  admittedAt      DateTime              @default(now())
  dischargedAt    DateTime?
  status          HospitalizationStatus @default(ADMITTED)
  admissionReason String
  dischargeReason String?
  bedNumber       String?
  physicianId     String?
  nurseInChargeId String?
  syncedAt        DateTime?
  sourceNode      String?
  version         Int                   @default(1)
  bed             Bed?                  @relation("HospitalizationBed")
  Consultation    Consultation[]
  nurseInCharge   User?                 @relation("HospitalizationNurse", fields: [nurseInChargeId], references: [id])
  patient         Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  physician       User?                 @relation("HospitalizationPhysician", fields: [physicianId], references: [id])
  ServiceUnit     ServiceUnit?          @relation(fields: [serviceUnitId], references: [id])
  deletedAt       DateTime?
}

/// Vital signs recorded by nurses.
model VitalSign {
  id             String        @id @default(uuid())
  patientId      String
  recordedById   String?
  type           VitalType
  value          String
  unit           String
  recordedAt     DateTime      @default(now())
  note           String?
  consultationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int           @default(1)
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy     User?         @relation("VitalSignRecordedBy", fields: [recordedById], references: [id])

  @@index([patientId, type, recordedAt])
}

/// Clinical encounters and consultations.
model Consultation {
  id                     String                   @id @default(uuid())
  patientId              String
  appointmentId          String                   @unique
  clinicId               String?
  hospitalizationId      String?
  providerId             String?
  status                 ConsultationStatus       @default(DRAFT)
  encounterType          EncounterType            @default(OUTPATIENT)
  chiefComplaint         String?
  clinicalSummary        String?
  diagnosis              String?
  assessment             String?
  plan                   String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  deletedAt              DateTime?
  syncedAt               DateTime?
  sourceNode             String?
  version                Int                      @default(1)
  appointment            Appointment              @relation("AppointmentConsultation", fields: [appointmentId], references: [id], onDelete: Cascade)
  hospitalization        Hospitalization?         @relation(fields: [hospitalizationId], references: [id])
  patient                Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider               User?                    @relation("ConsultationProvider", fields: [providerId], references: [id])
  notes                  ConsultationNote[]
  imagingRequests        ImagingRequest[]
  labRequests            LabRequest[]
  prescriptions          Prescription[]
  surgicalPlanned        Surgery[]
  vitalSigns             VitalSign[]
  Diagnosis              Diagnosis[]
  InsuranceAuthorization InsuranceAuthorization[]

  @@index([patientId, status])
  @@index([providerId])
  @@index([clinicId])
}

model ConsultationNote {
  id             String       @id @default(uuid())
  consultationId String
  authorId       String?
  noteType       String       @default("GENERAL")
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int          @default(1)
  author         User?        @relation("ConsultationNoteAuthor", fields: [authorId], references: [id])
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
}

/// Prescriptions and pharmacy workflow.
model Prescription {
  id                String             @id @default(uuid())
  consultationId    String
  patientId         String
  prescriberId      String?
  clinicId          String?
  status            PrescriptionStatus @default(PRESCRIBED)
  prescribingDate   DateTime           @default(now())
  instruction       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  syncedAt          DateTime?
  sourceNode        String?
  version           Int                @default(1)
  pharmacyDispenses PharmacyDispense[]
  consultation      Consultation       @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient           Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriber        User?              @relation("PrescriptionPrescriber", fields: [prescriberId], references: [id])
  lineItems         PrescriptionLine[]

  @@index([patientId, status])
  @@index([clinicId])
}

model PrescriptionLine {
  id             String              @id @default(uuid())
  prescriptionId String
  medicationId   String
  dosage         String
  route          MedicationRoute
  frequency      MedicationFrequency
  quantity       Int
  durationDays   Int?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int                 @default(1)
  medication     Medication          @relation(fields: [medicationId], references: [id])
  prescription   Prescription        @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model Medication {
  id                    String                 @id @default(uuid())
  code                  String                 @unique
  name                  String
  description           String?
  unit                  String
  strength              String?
  manufacturer          String?
  isControlled          Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  syncedAt              DateTime?
  sourceNode            String?
  version               Int                    @default(1)
  pharmacyDispenseLines PharmacyDispenseLine[]
  prescriptionLines     PrescriptionLine[]
  PurchaseOrderLine     PurchaseOrderLine[]
  GoodsReceiptLine      GoodsReceiptLine[]
  StockLot              StockLot[]
  StockTransaction      StockTransaction[]
}

model PharmacyDispense {
  id             String                 @id @default(uuid())
  prescriptionId String
  dispensedById  String?
  dispensedAt    DateTime               @default(now())
  status         PrescriptionStatus     @default(DISPENSED)
  notes          String?
  location       String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int                    @default(1)
  clinicId       String?
  dispensedBy    User?                  @relation("PharmacyDispenseDispenser", fields: [dispensedById], references: [id])
  prescription   Prescription           @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  lines          PharmacyDispenseLine[]

  @@index([clinicId])
}

model PharmacyDispenseLine {
  id                 String           @id @default(uuid())
  pharmacyDispenseId String
  medicationId       String
  quantity           Int
  unitPrice          Decimal          @db.Decimal(12, 2)
  totalPrice         Decimal          @db.Decimal(12, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  syncedAt           DateTime?
  sourceNode         String?
  version            Int              @default(1)
  medication         Medication       @relation(fields: [medicationId], references: [id])
  pharmacyDispense   PharmacyDispense @relation(fields: [pharmacyDispenseId], references: [id], onDelete: Cascade)
}

/// Laboratory workflow.
model LabRequest {
  id                String           @id @default(uuid())
  consultationId    String
  patientId         String
  requestedById     String?
  clinicId          String?
  status            LabRequestStatus @default(REQUESTED)
  requestedAt       DateTime         @default(now())
  receivedAt        DateTime?
  performedAt       DateTime?
  completedAt       DateTime?
  sentAt            DateTime?
  accessionNumber   String?          @unique
  externalReference String?
  specimenType      String?
  priority          String?          @default("NORMAL")
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @default(now())
  deletedAt         DateTime?
  syncedAt          DateTime?
  sourceNode        String?
  version           Int              @default(1)

  consultation Consultation      @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient      Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requestedBy  User?             @relation("LabRequestRequester", fields: [requestedById], references: [id])
  items        LabRequestItem[]
  samples      LabSample[]
  events       LabRequestEvent[]
  results      LabResult[]
  reports      LabReport[]

  @@index([status])
  @@index([clinicId])
}

model LabRequestItem {
  id                String               @id @default(uuid())
  labRequestId      String
  labTestId         String
  sampleTypeId      String?
  status            LabRequestItemStatus @default(REQUESTED)
  specimenLabel     String?
  assignedToId      String?
  requestedAt       DateTime             @default(now())
  collectedAt       DateTime?
  receivedAt        DateTime?
  analysisStartedAt DateTime?
  completedAt       DateTime?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @default(now())
  deletedAt         DateTime?
  syncedAt          DateTime?
  sourceNode        String?
  version           Int                  @default(1)

  labRequest LabRequest        @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  labTest    LabTest           @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  sampleType LabSampleType?    @relation(fields: [sampleTypeId], references: [id])
  assignedTo User?             @relation("LabRequestItemAssignedTo", fields: [assignedToId], references: [id])
  samples    LabSample[]
  results    LabResult[]
  events     LabRequestEvent[]
  reports    LabReport[]

  @@index([labRequestId])
  @@index([labTestId])
  @@index([status])
