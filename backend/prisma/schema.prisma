}

model LabCategory {
  id          String   @id @default(uuid())
  sectionId   String?
  name        String
  code        String?  @unique
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  section LabSection? @relation(fields: [sectionId], references: [id])
  tests   LabTest[]

  @@unique([sectionId, name])
}

model LabTest {
  id                    String            @id @default(uuid())
  code                  String            @unique
  name                  String
  categoryId            String
  sectionId             String?
  description           String?
  price                 Decimal           @db.Decimal(12, 2)
  turnaroundTimeMinutes Int?
  resultType            LabResultType     @default(MULTI_PARAMETER)
  unit                  String?
  referenceRange        String?
  genderRestriction     GenderRestriction @default(ALL)
  minAge                Int?
  maxAge                Int?
  active                Boolean           @default(true)
  createdById           String?
  updatedById           String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @default(now())

  category               LabCategory                    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  section                LabSection?                    @relation(fields: [sectionId], references: [id])
  createdBy              User?                          @relation("LabTestCreatedBy", fields: [createdById], references: [id])
  updatedBy              User?                          @relation("LabTestUpdatedBy", fields: [updatedById], references: [id])
  sampleRequirements     LabTestSampleRequirement[]
  consumableRequirements LabTestConsumableRequirement[]
  parameterTemplates     LabTestParameter[]
  requestItems           LabRequestItem[]

  @@index([categoryId])
}

model LabTestParameter {
  id             String        @id @default(uuid())
  labTestId      String
  code           String
  name           String
  unit           String?
  resultType     LabResultType @default(NUMERIC)
  referenceRange String?
