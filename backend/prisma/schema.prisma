  PUBLIC
  CORPORATE
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum ClaimDecision {
  MANUAL
  AUTOMATIC
}

enum AuthorizationStatus {
  REQUESTED
  AUTHORIZED
  DENIED
  EXPIRED
}

model Insurance {
  id          String        @id @default(uuid())
  name        String
  type        InsuranceType @default(PRIVATE)
  address     String?
  phone       String?
  email       String?
  contactName String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  policies InsurancePolicy[]
}

model InsurancePolicy {
  id            String       @id @default(uuid())
  insuranceId   String
  patientId     String
  policyNumber  String
  effectiveDate DateTime
  expiryDate    DateTime?
  status        PolicyStatus @default(ACTIVE)
  coverage      Json?
  holderName    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  insurance              Insurance                @relation(fields: [insuranceId], references: [id], onDelete: Cascade)
  patient                Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  InsuranceClaim         InsuranceClaim[]
  InsuranceAuthorization InsuranceAuthorization[]

  @@unique([insuranceId, policyNumber])
  @@index([patientId])
}

model InsuranceClaim {
  id              String         @id @default(uuid())
  policyId        String
  patientId       String
  invoiceId       String?
  amountClaimed   Decimal        @db.Decimal(12, 2)
  amountApproved  Decimal?       @db.Decimal(12, 2)
  status          ClaimStatus    @default(DRAFT)
  decision        ClaimDecision?
  rejectionReason String?
  submittedAt     DateTime?
  decidedAt       DateTime?
  processedById   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  policy      InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  patient     Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])
  processedBy User?           @relation(fields: [processedById], references: [id])

  @@index([policyId])
  @@index([patientId])
}

model InsuranceAuthorization {
  id             String              @id @default(uuid())
  policyId       String
  patientId      String
  consultationId String?
  serviceId      String?
  status         AuthorizationStatus @default(REQUESTED)
  requestedAt    DateTime            @default(now())
  authorizedAt   DateTime?
  authorizedById String?
  expiresAt      DateTime?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  policy       InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  patient      Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultation Consultation?   @relation(fields: [consultationId], references: [id])
  authorizedBy User?           @relation(fields: [authorizedById], references: [id])

  @@index([policyId])
}

/// == Pharmacie avancée (achats, lots, valorisation) ==
enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum GoodsReceiptStatus {
  RECEIVED
  INSPECTED
  REJECTED
}

enum SupplierInvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model Pharmacy {
  id        String   @id @default(uuid())
  clinicId  String?
  name      String
  location  String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic?           @relation(fields: [clinicId], references: [id])
  stocks MedicationStock[]
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  supplierId  String
  clinicId    String?
  orderNumber String              @unique
  status      PurchaseOrderStatus @default(DRAFT)
  orderedById String?
  orderedAt   DateTime            @default(now())
  expectedAt  DateTime?
  totalAmount Decimal?            @db.Decimal(12, 2)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  clinic          Clinic?             @relation(fields: [clinicId], references: [id])
  lines           PurchaseOrderLine[]
  goodsReceipts   GoodsReceipt[]
  SupplierInvoice SupplierInvoice[]

  @@index([supplierId])
  @@index([clinicId])
}

model PurchaseOrderLine {
  id              String   @id @default(uuid())
  purchaseOrderId String
  medicationId    String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  totalPrice      Decimal  @db.Decimal(12, 2)
  currency        String?  @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  medication    Medication    @relation(fields: [medicationId], references: [id])

  @@index([purchaseOrderId])
  @@index([medicationId])
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  purchaseOrderId String?
  supplierId      String?
  receivedAt      DateTime           @default(now())
  receivedById    String?
  status          GoodsReceiptStatus @default(RECEIVED)
  notes           String?
  createdAt       DateTime           @default(now())

  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  receivedBy    User?              @relation(fields: [receivedById], references: [id])
  lines         GoodsReceiptLine[]

  @@index([purchaseOrderId])
}

model GoodsReceiptLine {
  id             String    @id @default(uuid())
  goodsReceiptId String
  medicationId   String
  quantity       Int
  unitPrice      Decimal   @db.Decimal(12, 2)
  batchNumber    String?
  expiryDate     DateTime?
  createdAt      DateTime  @default(now())

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  medication   Medication   @relation(fields: [medicationId], references: [id])

  @@index([goodsReceiptId])
  @@index([medicationId])
}

model SupplierInvoice {
  id                    String                @id @default(uuid())
  supplierId            String
  supplierInvoiceNumber String?
  purchaseOrderId       String?
  amount                Decimal               @db.Decimal(12, 2)
  status                SupplierInvoiceStatus @default(DRAFT)
  issuedAt              DateTime?
  dueDate               DateTime?
  createdAt             DateTime              @default(now())

  supplier        Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  SupplierPayment SupplierPayment[]

  @@index([supplierId])
}

model SupplierPayment {
  id                String   @id @default(uuid())
  supplierId        String
  supplierInvoiceId String?
  amount            Decimal  @db.Decimal(12, 2)
  paidAt            DateTime @default(now())
  method            String?
  reference         String?
  createdAt         DateTime @default(now())

  supplier        Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierInvoice SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])

  @@index([supplierId])
}

/// Stock lot tracking and valuation
model StockLot {
  id            String    @id @default(uuid())
  medicationId  String
  clinicId      String?
  batchNumber   String
  quantity      Int
  purchasePrice Decimal?  @db.Decimal(12, 2)
  expiryDate    DateTime?
  receivedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())

  medication       Medication         @relation(fields: [medicationId], references: [id])
  clinic           Clinic?            @relation(fields: [clinicId], references: [id])
  StockTransaction StockTransaction[]

  @@index([medicationId])
  @@index([batchNumber])
  @@index([clinicId])
}

model StockTransaction {
  id            String   @id @default(uuid())
  medicationId  String
  lotId         String?
  type          String
  quantity      Int
  unitPrice     Decimal? @db.Decimal(12, 2)
  reference     String?
  performedById String?
  clinicId      String?
  createdAt     DateTime @default(now())

  medication  Medication @relation(fields: [medicationId], references: [id])
  lot         StockLot?  @relation(fields: [lotId], references: [id])
  performedBy User?      @relation(fields: [performedById], references: [id])
  clinic      Clinic?    @relation(fields: [clinicId], references: [id])

  @@index([medicationId, createdAt])
}

/// == Ressources humaines ==
enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
}

enum ContractType {
  PERMANENT
  TEMPORARY
  CONTRACTOR
}

enum ShiftType {
  DAY
  NIGHT
  ROTATING
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

model Employee {
  id              String         @id @default(uuid())
  userId          String?
  clinicId        String?
  employeeNumber  String?        @unique
  firstName       String
  lastName        String
  gender          String?
  dateOfBirth     DateTime?
  hireDate        DateTime?
  terminationDate DateTime?
  status          EmployeeStatus @default(ACTIVE)
  position        String?
  departmentId    String?
  serviceUnitId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user          User?              @relation(fields: [userId], references: [id])
  clinic        Clinic?            @relation(fields: [clinicId], references: [id])
  department    Department?        @relation(fields: [departmentId], references: [id])
  serviceUnit   ServiceUnit?       @relation(fields: [serviceUnitId], references: [id])
  contracts     EmployeeContract[]
  shifts        Shift[]
  attendances   Attendance[]
  leaveRequests LeaveRequest[]
  payrolls      Payroll[]

  @@index([userId])
  @@index([clinicId])
}

model EmployeeContract {
  id         String       @id @default(uuid())
  employeeId String
  type       ContractType @default(PERMANENT)
  startDate  DateTime
  endDate    DateTime?
  salary     Decimal?     @db.Decimal(12, 2)
  currency   String?      @default("USD")
  frequency  String? // e.g. MONTHLY
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Shift {
  id         String    @id @default(uuid())
  employeeId String
  startAt    DateTime
  endAt      DateTime
  type       ShiftType
  createdAt  DateTime  @default(now())

  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  Attendance Attendance[]

  @@index([employeeId, startAt])
}

model Attendance {
  id         String           @id @default(uuid())
  employeeId String
  shiftId    String?
  clockInAt  DateTime?
  clockOutAt DateTime?
  status     AttendanceStatus @default(PRESENT)
  createdAt  DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@index([employeeId])
}

model LeaveRequest {
  id          String      @id @default(uuid())
  employeeId  String
  leaveType   String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      LeaveStatus @default(PENDING)
  requestedAt DateTime    @default(now())
  decidedAt   DateTime?
  decidedById String?

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  decidedBy User?    @relation(fields: [decidedById], references: [id])

  @@index([employeeId, status])
}

model Payroll {
  id            String        @id @default(uuid())
  employeeId    String
  periodStart   DateTime
  periodEnd     DateTime
  grossAmount   Decimal       @db.Decimal(12, 2)
  netAmount     Decimal       @db.Decimal(12, 2)
  taxes         Json?
  deductions    Json?
  status        PayrollStatus @default(DRAFT)
  processedAt   DateTime?
  processedById String?
  createdAt     DateTime      @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  processedBy User?    @relation(fields: [processedById], references: [id])

  @@index([employeeId, status])
}

/// == Audit et sécurité ==
model AuditTrail {
  id        String      @id @default(uuid())
  actorId   String?
  entity    String
  entityId  String
  action    AuditAction
  before    Json?
  after     Json?
  changedAt DateTime    @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  changedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum LoginResult {
  SUCCESS
  FAILURE
}

model LoginAttempt {
  id         String      @id @default(uuid())
  userId     String?
  username   String?
  result     LoginResult @default(FAILURE)
  ipAddress  String?
  userAgent  String?
  occurredAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model Session {
  id         String        @id @default(uuid())
  userId     String
  tokenHash  String
  ipAddress  String?
  userAgent  String?
  lastSeenAt DateTime?
  expiresAt  DateTime?
  status     SessionStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

/// == Sécurité supplémentaire ==
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// == Indexes et contraintes supplémentaires recommandées ==
// - ajouter des index sur les colonnes fréquemment filtrées (clinicId, patientId, createdAt)
// - utiliser @@unique pour les champs business (orderNumber, policyNumber, employeeNumber)
