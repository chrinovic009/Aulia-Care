  BLOOD_PRESSURE
  HEART_RATE
  RESPIRATORY_RATE
  OXYGEN_SATURATION
  WEIGHT
  HEIGHT
  BLOOD_GLUCOSE
  CHEST_CIRCUMFERENCE
  ARM_CIRCUMFERENCE
}

enum LabRequestStatus {
  REQUESTED
  COLLECTED
  RECEIVED
  IN_ANALYSIS
