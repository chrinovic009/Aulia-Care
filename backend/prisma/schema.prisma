  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now())

  labTest          LabTest              @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  resultParameters LabResultParameter[]

  @@index([labTestId])
}

model LabTestSampleRequirement {
  id               String   @id @default(uuid())
  labTestId        String
  labSampleTypeId  String
  volumeRequired   Decimal? @db.Decimal(12, 2)
  volumeUnit       String?  @default("mL")
  storageCondition String?
  maxAgeMinutes    Int?
  instructions     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  labTest       LabTest       @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  labSampleType LabSampleType @relation(fields: [labSampleTypeId], references: [id], onDelete: Cascade)

  @@index([labTestId])
  @@index([labSampleTypeId])
}

model LabConsumable {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  unit        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  stock        LabConsumableStock[]
  transactions LabConsumableTransaction[]
  requirements LabTestConsumableRequirement[]
}

model LabTestConsumableRequirement {
  id              String   @id @default(uuid())
  labTestId       String
  labConsumableId String
  quantity        Decimal  @db.Decimal(12, 2)
  unit            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  labTest       LabTest       @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  labConsumable LabConsumable @relation(fields: [labConsumableId], references: [id], onDelete: Cascade)

  @@index([labTestId])
  @@index([labConsumableId])
}

model LabConsumableStock {
  id              String   @id @default(uuid())
  labConsumableId String
  quantity        Decimal  @default(0) @db.Decimal(12, 2)
  minimumLevel    Decimal? @db.Decimal(12, 2)
  criticalLevel   Decimal? @db.Decimal(12, 2)
