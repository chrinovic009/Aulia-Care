generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles, permissions and users.
model Role {
  id          String           @id @default(uuid())
  slug        RoleSlug         @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int              @default(1)
  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  action      PermissionAction
  resource    String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int              @default(1)
  roles       RolePermission[]

  @@unique([action, resource])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  syncedAt     DateTime?
  sourceNode   String?
  version      Int        @default(1)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id                          String               @id @default(uuid())
  email                       String               @unique
  username                    String               @unique
  displayName                 String
  firstName                   String
  lastName                    String
  passwordHash                String
  status                      UserStatus           @default(ACTIVE)
  primaryRole                 RoleSlug?
  specialty                   String?
  bio                         String?
  profilePhotoUrl             String?
  phone                       String?
  whatsappUrl                 String?
  facebookUrl                 String?
  instagramUrl                String?
  linkedinUrl                 String?
  nationality                 String?
  addressCountry              String?
  addressProvince             String?
  addressCity                 String?
  addressNeighborhood         String?
  addressStreet               String?
  lastLoginAt                 DateTime?
  preferredLanguage           String?              @default("fr")
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  deletedAt                   DateTime?
  syncedAt                    DateTime?
  sourceNode                  String?
  version                     Int                  @default(1)
  appointmentsRequested       Appointment[]        @relation("AppointmentRequester")
  auditLogs                   AuditLog[]
  providedConsultations       Consultation[]       @relation("ConsultationProvider")
  consultationNotesAuthored   ConsultationNote[]   @relation("ConsultationNoteAuthor")
  hospitalizationsAsNurse     Hospitalization[]    @relation("HospitalizationNurse")
  hospitalizationsAsPhysician Hospitalization[]    @relation("HospitalizationPhysician")
  imagingReportsInterpreted   ImagingReport[]      @relation("ImagingReportInterpreter")
  imagingRequestsRequested    ImagingRequest[]     @relation("ImagingRequestRequester")
  invoicesIssued              Invoice[]            @relation("InvoiceIssuer")
  labRequestsRequested        LabRequest[]         @relation("LabRequestRequester")
  labResultsReported          LabResult[]          @relation("LabResultReporter")
  medicalHistoriesCreated     MedicalHistory[]     @relation("MedicalHistoryCreatedBy")
  notificationsSent           Notification[]       @relation("NotificationAuthor")
  notifications               Notification[]       @relation("NotificationRecipient")
  sentChatMessages            ChatMessage[]        @relation("ChatMessageSender")
  receivedChatMessages        ChatMessage[]        @relation("ChatMessageRecipient")
  registeredPatients          Patient[]            @relation("PatientReceptionist")
  paymentsMade                Payment[]            @relation("PaymentPayer")
  pharmacyDispenses           PharmacyDispense[]   @relation("PharmacyDispenseDispenser")
  prescriptionsPrescribed     Prescription[]       @relation("PrescriptionPrescriber")
  refreshTokens               RefreshToken[]
  serviceResponsabilites      ServiceResponsable[]
  staff                       ServiceStaff[]
  surgeriesAsAnesthesiologist Surgery[]            @relation("SurgeryAnesthesiologist")
  surgeriesAsSurgeon          Surgery[]            @relation("SurgerySurgeon")
  roles                       UserRole[]
  vitalSignsRecorded          VitalSign[]          @relation("VitalSignRecordedBy")

  @@index([primaryRole])
}

model UserRole {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  active     Boolean   @default(true)
  assignedAt DateTime  @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Department {
  id          String         @id @default(uuid())
  name        String         @unique
  type        DepartmentType
  code        String         @unique
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int            @default(1)
  services    ServiceUnit[]
}

model ServiceUnit {
  id               String            @id @default(uuid())
  name             String
  departmentId     String
  location         String?
  contactNumber    String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  syncedAt         DateTime?
  sourceNode       String?
  version          Int               @default(1)
  appointments     Appointment[]
  hospitalizations Hospitalization[]
  rooms            Room[]
  department       Department        @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, name])
}

/// Central services catalog (e.g. Cardiologie, Radiologie)
model Service {
  id           String               @id @default(uuid())
  name         String               @unique
  description  String?
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  syncedAt     DateTime?
  sourceNode   String?
  version      Int                  @default(1)
  patients     Patient[]
  responsables ServiceResponsable[]
  staff        ServiceStaff[]
  tarifs       ServiceTarif[]
}

/// ServiceTarif allows historisation of service prices
model ServiceTarif {
  id         String    @id @default(uuid())
  serviceId  String
  prix       Decimal   @db.Decimal(12, 2)
  dateDebut  DateTime  @default(now())
  dateFin    DateTime?
  actif      Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model AdmissionFee {
  id         String    @id @default(uuid())
  label      String    @default("Frais de fiche d'admission")
  amount     Decimal   @db.Decimal(12, 2)
  currency   String    @default("USD")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
}

model ServiceStaff {
  id            String    @id @default(uuid())
  serviceId     String
  userId        String
  roleInService String?
  actif         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  syncedAt      DateTime?
  sourceNode    String?
  version       Int       @default(1)
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serviceId, userId])
}

/// ServiceResponsable links services to users (physicians)
model ServiceResponsable {
  id         String    @id @default(uuid())
  serviceId  String
  userId     String
  principal  Boolean   @default(false)
  actif      Boolean   @default(true)
  createdAt  DateTime  @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Patients and clinical records.
model Patient {
  id                String                @id @default(uuid())
  firstName         String
  lastName          String
  middleName        String?
  gender            String
  profession        String?
  dateOfBirth       DateTime
  externalId        String?               @unique
  phone             String?
  email             String?               @unique
  address           String?
  city              String?
  postalCode        String?
  nationality       String?
  bloodType         String?
  emergencyContact  String?
  emergencyPhone    String?
  insuranceProvider String?
  insuranceNumber   String?
  status            String                @default("ACTIVE")
  workflowStatus    PatientWorkflowStatus @default(EN_ATTENTE_DE_PAIEMENT)
  admissionType     String?
  priority          String?
  arrivalAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  receptionistId    String?
  serviceId         String?
  syncedAt          DateTime?
  sourceNode        String?
  version           Int                   @default(1)
  appointments      Appointment[]
  auditLogs         AuditLog[]
  consultations     Consultation[]
  hospitalizations  Hospitalization[]
  imagingRequests   ImagingRequest[]
  invoices          Invoice[]
  labRequests       LabRequest[]
  medicalHistories  MedicalHistory[]
  notifications     Notification[]
  receptionist      User?                 @relation("PatientReceptionist", fields: [receptionistId], references: [id])
  service           Service?              @relation(fields: [serviceId], references: [id])
  familyContacts    PatientContact[]
  prescriptions     Prescription[]
  surgeries         Surgery[]
  vitalSigns        VitalSign[]

  @@index([lastName, firstName])
  @@index([dateOfBirth])
}

model PatientContact {
  id           String    @id @default(uuid())
  patientId    String
  name         String
  relationship String?
  phone        String?
  email        String?
  address      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  syncedAt     DateTime?
  sourceNode   String?
  version      Int       @default(1)
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Room {
  id            String      @id @default(uuid())
  number        String      @unique
  serviceUnitId String
  status        RoomStatus  @default(AVAILABLE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  syncedAt      DateTime?
  sourceNode    String?
  version       Int         @default(1)
  beds          Bed[]
  serviceUnit   ServiceUnit @relation(fields: [serviceUnitId], references: [id])
}

model Bed {
  id                String           @id @default(uuid())
  roomId            String
  code              String
  status            BedStatus        @default(FREE)
  hospitalizationId String?          @unique
  createdAt         DateTime         @default(now())
  syncedAt          DateTime?
  sourceNode        String?
  version           Int              @default(1)
  hospitalization   Hospitalization? @relation("HospitalizationBed", fields: [hospitalizationId], references: [id])
  room              Room             @relation(fields: [roomId], references: [id])
}

model MedicalHistory {
  id          String    @id @default(uuid())
  patientId   String
  eventDate   DateTime  @default(now())
  kind        String
  details     String
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int       @default(1)
  createdBy   User?     @relation("MedicalHistoryCreatedBy", fields: [createdById], references: [id])
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

/// Appointments and scheduling.
model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  requestedById   String?
  serviceUnitId   String?
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  reason          String?
  status          AppointmentStatus @default(SCHEDULED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  syncedAt        DateTime?
  sourceNode      String?
  version         Int               @default(1)
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requestedBy     User?             @relation("AppointmentRequester", fields: [requestedById], references: [id])
  serviceUnit     ServiceUnit?      @relation(fields: [serviceUnitId], references: [id])
  consultation    Consultation?     @relation("AppointmentConsultation")

  @@index([scheduledAt])
  @@index([status])
}

model Hospitalization {
  id              String                @id @default(uuid())
  patientId       String
  serviceUnitId   String?
  admittedAt      DateTime              @default(now())
  dischargedAt    DateTime?
  status          HospitalizationStatus @default(ADMITTED)
  admissionReason String
  dischargeReason String?
  bedNumber       String?
  physicianId     String?
  nurseInChargeId String?
  syncedAt        DateTime?
  sourceNode      String?
  version         Int                   @default(1)
  bed             Bed?                  @relation("HospitalizationBed")
  Consultation    Consultation[]
  nurseInCharge   User?                 @relation("HospitalizationNurse", fields: [nurseInChargeId], references: [id])
  patient         Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  physician       User?                 @relation("HospitalizationPhysician", fields: [physicianId], references: [id])
  ServiceUnit     ServiceUnit?          @relation(fields: [serviceUnitId], references: [id])
}

/// Vital signs recorded by nurses.
model VitalSign {
  id             String        @id @default(uuid())
  patientId      String
  recordedById   String?
  type           VitalType
  value          String
  unit           String
  recordedAt     DateTime      @default(now())
  note           String?
  consultationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int           @default(1)
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy     User?         @relation("VitalSignRecordedBy", fields: [recordedById], references: [id])

  @@index([patientId, type, recordedAt])
}

/// Clinical encounters and consultations.
model Consultation {
  id                String             @id @default(uuid())
  patientId         String
  appointmentId     String             @unique
  hospitalizationId String?
  providerId        String?
  status            ConsultationStatus @default(DRAFT)
  encounterType     EncounterType      @default(OUTPATIENT)
  chiefComplaint    String?
  clinicalSummary   String?
  diagnosis         String?
  assessment        String?
  plan              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  syncedAt          DateTime?
  sourceNode        String?
  version           Int                @default(1)
  appointment       Appointment        @relation("AppointmentConsultation", fields: [appointmentId], references: [id], onDelete: Cascade)
  hospitalization   Hospitalization?   @relation(fields: [hospitalizationId], references: [id])
  patient           Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider          User?              @relation("ConsultationProvider", fields: [providerId], references: [id])
  notes             ConsultationNote[]
  imagingRequests   ImagingRequest[]
  labRequests       LabRequest[]
  prescriptions     Prescription[]
  surgicalPlanned   Surgery[]
  vitalSigns        VitalSign[]

  @@index([patientId, status])
  @@index([providerId])
}

model ConsultationNote {
  id             String       @id @default(uuid())
  consultationId String
  authorId       String?
  noteType       String       @default("GENERAL")
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int          @default(1)
  author         User?        @relation("ConsultationNoteAuthor", fields: [authorId], references: [id])
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
}

/// Prescriptions and pharmacy workflow.
model Prescription {
  id                String             @id @default(uuid())
  consultationId    String
  patientId         String
  prescriberId      String?
  status            PrescriptionStatus @default(PRESCRIBED)
  prescribingDate   DateTime           @default(now())
  instruction       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  syncedAt          DateTime?
  sourceNode        String?
  version           Int                @default(1)
  pharmacyDispenses PharmacyDispense[]
  consultation      Consultation       @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient           Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriber        User?              @relation("PrescriptionPrescriber", fields: [prescriberId], references: [id])
  lineItems         PrescriptionLine[]

  @@index([patientId, status])
}

model PrescriptionLine {
  id             String              @id @default(uuid())
  prescriptionId String
  medicationId   String
  dosage         String
  route          MedicationRoute
  frequency      MedicationFrequency
  quantity       Int
  durationDays   Int?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int                 @default(1)
  medication     Medication          @relation(fields: [medicationId], references: [id])
  prescription   Prescription        @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model Medication {
  id                    String                 @id @default(uuid())
  code                  String                 @unique
  name                  String
  description           String?
  unit                  String
  strength              String?
  manufacturer          String?
  isControlled          Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  syncedAt              DateTime?
  sourceNode            String?
  version               Int                    @default(1)
  pharmacyDispenseLines PharmacyDispenseLine[]
  prescriptionLines     PrescriptionLine[]
}

model PharmacyDispense {
  id             String                 @id @default(uuid())
  prescriptionId String
  dispensedById  String?
  dispensedAt    DateTime               @default(now())
  status         PrescriptionStatus     @default(DISPENSED)
  notes          String?
  location       String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int                    @default(1)
  dispensedBy    User?                  @relation("PharmacyDispenseDispenser", fields: [dispensedById], references: [id])
  prescription   Prescription           @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  lines          PharmacyDispenseLine[]
}

model PharmacyDispenseLine {
  id                 String           @id @default(uuid())
  pharmacyDispenseId String
  medicationId       String
  quantity           Int
  unitPrice          Decimal          @db.Decimal(12, 2)
  totalPrice         Decimal          @db.Decimal(12, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  syncedAt           DateTime?
  sourceNode         String?
  version            Int              @default(1)
  medication         Medication       @relation(fields: [medicationId], references: [id])
  pharmacyDispense   PharmacyDispense @relation(fields: [pharmacyDispenseId], references: [id], onDelete: Cascade)
}

/// Laboratory workflow.
model LabRequest {
  id             String           @id @default(uuid())
  consultationId String
  patientId      String
  requestedById  String?
  status         LabRequestStatus @default(REQUESTED)
  requestedAt    DateTime         @default(now())
  performedAt    DateTime?
  completedAt    DateTime?
  specimenType   String?
  priority       String?          @default("NORMAL")
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int              @default(1)
  consultation   Consultation     @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient        Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requestedBy    User?            @relation("LabRequestRequester", fields: [requestedById], references: [id])
  results        LabResult[]

  @@index([status])
}

model LabResult {
  id             String     @id @default(uuid())
  labRequestId   String
  resultCode     String
  resultName     String
  resultValue    String
  units          String?
  referenceRange String?
  interpretation String?
  reportedById   String?
  reportedAt     DateTime   @default(now())
  verified       Boolean    @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int        @default(1)
  labRequest     LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  reportedBy     User?      @relation("LabResultReporter", fields: [reportedById], references: [id])

  @@index([resultCode])
}

/// Imaging workflow.
model ImagingRequest {
  id             String               @id @default(uuid())
  consultationId String
  patientId      String
  requestedById  String?
  status         ImagingRequestStatus @default(REQUESTED)
  modality       String
  bodyPart       String
  urgency        String?              @default("ROUTINE")
  scheduledAt    DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int                  @default(1)
  report         ImagingReport?
  consultation   Consultation         @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient        Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requestedBy    User?                @relation("ImagingRequestRequester", fields: [requestedById], references: [id])

  @@index([status])
}

model ImagingReport {
  id               String         @id @default(uuid())
  imagingRequestId String         @unique
  interpretedById  String?
  findings         String
  impression       String
  recommendations  String?
  reportedAt       DateTime       @default(now())
  verified         Boolean        @default(false)
  verifiedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  syncedAt         DateTime?
  sourceNode       String?
  version          Int            @default(1)
  imagingRequest   ImagingRequest @relation(fields: [imagingRequestId], references: [id], onDelete: Cascade)
  interpretedBy    User?          @relation("ImagingReportInterpreter", fields: [interpretedById], references: [id])
}

/// Surgery and bloc op�ratoire.
model OperatingRoom {
  id         String    @id @default(uuid())
  name       String    @unique
  location   String?
  capacity   Int       @default(1)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  surgeries  Surgery[]
}

model Surgery {
  id                 String         @id @default(uuid())
  patientId          String
  consultationId     String?
  operatingRoomId    String?
  surgeonId          String?
  anesthesiologistId String?
  scheduledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  status             SurgeryStatus  @default(PLANNED)
  procedureName      String
  indication         String
  findings           String?
  postoperativePlan  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  syncedAt           DateTime?
  sourceNode         String?
  version            Int            @default(1)
  anesthesiologist   User?          @relation("SurgeryAnesthesiologist", fields: [anesthesiologistId], references: [id])
  consultation       Consultation?  @relation(fields: [consultationId], references: [id])
  operatingRoom      OperatingRoom? @relation(fields: [operatingRoomId], references: [id])
  patient            Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  surgeon            User?          @relation("SurgerySurgeon", fields: [surgeonId], references: [id])

  @@index([status])
  @@index([scheduledAt])
}

/// Billing and payments.
model Invoice {
  id          String        @id @default(uuid())
  patientId   String
  issuedById  String?
  type        InvoiceType   @default(ADMISSION_FEE)
  status      InvoiceStatus @default(PENDING)
  issuedAt    DateTime      @default(now())
  totalAmount Decimal       @db.Decimal(12, 2)
  balanceDue  Decimal       @db.Decimal(12, 2)
  dueDate     DateTime?
  remarks     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?
  sourceNode  String?
  version     Int           @default(1)
  issuedBy    User?         @relation("InvoiceIssuer", fields: [issuedById], references: [id])
  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@index([status])
}

model Payment {
  id         String        @id @default(uuid())
  invoiceId  String
  paidById   String?
  amount     Decimal       @db.Decimal(12, 2)
  method     PaymentMethod
  paidAt     DateTime      @default(now())
  reference  String?
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?
  syncedAt   DateTime?
  sourceNode String?
  version    Int           @default(1)
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paidBy     User?         @relation("PaymentPayer", fields: [paidById], references: [id])
}

model Clinic {
  id          String    @id @default(uuid())
  name        String
  legalName   String?
  phone       String?
  email       String?
  address     String?
  city        String?
  country     String?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Supplier {
  id          String    @id @default(uuid())
  name        String
  phone       String?
  email       String?
  address     String?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model MedicationStock {
  id             String    @id @default(uuid())
  medicationId   String
  batchNumber    String?
  quantity       Int       @default(0)
  lowStockLevel  Int       @default(10)
  criticalLevel  Int       @default(3)
  purchasePrice  Decimal?  @db.Decimal(12, 2)
  expiryDate     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([medicationId])
  @@index([expiryDate])
}

model StockMovement {
  id            String    @id @default(uuid())
  medicationId  String
  supplierId    String?
  type          String
  quantity      Int
  unitPrice     Decimal?  @db.Decimal(12, 2)
  reason        String?
  reference     String?
  performedById String?
  createdAt     DateTime  @default(now())

  @@index([medicationId, createdAt])
  @@index([supplierId])
}

model InvoiceLine {
  id          String    @id @default(uuid())
  invoiceId   String
  serviceId   String?
  label       String
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalAmount Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([invoiceId])
  @@index([serviceId])
}

model PaymentValidation {
  id           String    @id @default(uuid())
  paymentId    String?
  invoiceId    String?
  validatorId  String?
  status       String    @default("PENDING")
  note         String?
  validatedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([invoiceId, status])
  @@index([paymentId])
}

model CashRegister {
  id          String    @id @default(uuid())
  cashierId   String?
  label       String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  openingCash Decimal   @default(0) @db.Decimal(12, 2)
  closingCash Decimal?  @db.Decimal(12, 2)
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())

  @@index([cashierId, status])
}

model Expense {
  id          String    @id @default(uuid())
  category    String
  label       String
  amount      Decimal   @db.Decimal(12, 2)
  paidAt      DateTime  @default(now())
  paidById    String?
  note        String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([paidAt])
}

model Revenue {
  id          String    @id @default(uuid())
  source      String
  serviceId   String?
  invoiceId   String?
  paymentId   String?
  amount      Decimal   @db.Decimal(12, 2)
  receivedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([receivedAt])
  @@index([serviceId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String
  userId     String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String               @id @default(uuid())
  patientId     String?
  recipientId   String?
  authorId      String?
  type          NotificationType     @default(ALERT)
  status        NotificationStatus   @default(UNREAD)
  priority      NotificationPriority @default(MEDIUM)
  title         String
  message       String
  relatedEntity String?
  relatedId     String?
  sendAt        DateTime?            @default(now())
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?
  syncedAt      DateTime?
  sourceNode    String?
  version       Int                  @default(1)
  author        User?                @relation("NotificationAuthor", fields: [authorId], references: [id])
  patient       Patient?             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recipient     User?                @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, status])
}

model ChatMessage {
  id              String        @id @default(uuid())
  senderId        String
  recipientId     String
  recipientType   String        @default("USER")
  text            String
  status          MessageStatus @default(SENT)
  deliveredAt     DateTime?
  readAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  sender          User          @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient       User          @relation("ChatMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, status])
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  patientId  String?
  action     AuditAction
  entity     String
  entityId   String
  summary    String
  metadata   Json?
  createdAt  DateTime    @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int         @default(1)
  actor      User?       @relation(fields: [actorId], references: [id])
  patient    Patient?    @relation(fields: [patientId], references: [id])

  @@index([actorId])
  @@index([patientId])
  @@index([entity, entityId])
}

model SyncEvent {
  id        String   @id @default(uuid())
  tableName String
  recordId  String
  operation String
  payload   Json
  synced    Boolean  @default(false)
  createdAt DateTime @default(now())
}

