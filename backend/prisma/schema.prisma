  updatedById     String?

  labConsumable LabConsumable @relation(fields: [labConsumableId], references: [id], onDelete: Cascade)
  updatedBy     User?         @relation("LabConsumableStockUpdatedBy", fields: [updatedById], references: [id])

  @@index([labConsumableId])
}

model LabConsumableTransaction {
  id              String                       @id @default(uuid())
  labConsumableId String
