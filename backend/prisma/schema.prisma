  updatedAt        DateTime        @default(now())

  labRequest     LabRequest      @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  labRequestItem LabRequestItem? @relation(fields: [labRequestItemId], references: [id])
  issuedBy       User?           @relation("LabReportIssuedBy", fields: [issuedById], references: [id])

  @@index([labRequestId])
  @@index([labRequestItemId])
}

model LabSectionStaff {
  id           String       @id @default(uuid())
  labSectionId String
  userId       String
  role         LabStaffRole @default(LAB_TECHNICIAN)
  active       Boolean      @default(true)
  assignedAt   DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now())

  labSection LabSection @relation(fields: [labSectionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([labSectionId, userId])
}

model LabConfiguration {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @default(now()) @updatedAt
}

model LabDailyStatistics {
  id                    String   @id @default(uuid())
  date                  DateTime @unique
  requestsCount         Int      @default(0)
  testsPerformed        Int      @default(0)
  revenue               Decimal  @default(0) @db.Decimal(14, 2)
  validatedCount        Int      @default(0)
  rejectedCount         Int      @default(0)
  averageTurnaroundMins Int?
  technicianMetrics     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())
}

/// Imaging workflow.
model ImagingRequest {
  id             String               @id @default(uuid())
  consultationId String
  patientId      String
  requestedById  String?
  status         ImagingRequestStatus @default(REQUESTED)
  modality       String
  bodyPart       String
  urgency        String?              @default("ROUTINE")
  scheduledAt    DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int                  @default(1)
  report         ImagingReport?
  consultation   Consultation         @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient        Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requestedBy    User?                @relation("ImagingRequestRequester", fields: [requestedById], references: [id])

  @@index([status])
}

model ImagingReport {
  id               String         @id @default(uuid())
  imagingRequestId String         @unique
  interpretedById  String?
  findings         String
  impression       String
  recommendations  String?
  reportedAt       DateTime       @default(now())
  verified         Boolean        @default(false)
  verifiedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  syncedAt         DateTime?
  sourceNode       String?
  version          Int            @default(1)
  imagingRequest   ImagingRequest @relation(fields: [imagingRequestId], references: [id], onDelete: Cascade)
  interpretedBy    User?          @relation("ImagingReportInterpreter", fields: [interpretedById], references: [id])
}

/// Surgery and bloc op�ratoire.
model OperatingRoom {
  id         String    @id @default(uuid())
  name       String    @unique
  location   String?
  capacity   Int       @default(1)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  surgeries  Surgery[]
}

model Surgery {
  id                 String         @id @default(uuid())
  patientId          String
  consultationId     String?
  operatingRoomId    String?
  surgeonId          String?
  anesthesiologistId String?
  scheduledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  status             SurgeryStatus  @default(PLANNED)
  procedureName      String
  indication         String
  findings           String?
  postoperativePlan  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  syncedAt           DateTime?
  sourceNode         String?
  version            Int            @default(1)
  anesthesiologist   User?          @relation("SurgeryAnesthesiologist", fields: [anesthesiologistId], references: [id])
  consultation       Consultation?  @relation(fields: [consultationId], references: [id])
  operatingRoom      OperatingRoom? @relation(fields: [operatingRoomId], references: [id])
  patient            Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  surgeon            User?          @relation("SurgerySurgeon", fields: [surgeonId], references: [id])

  @@index([status])
  @@index([scheduledAt])
}

/// Billing and payments.
model Invoice {
  id             String           @id @default(uuid())
  patientId      String
  issuedById     String?
  type           InvoiceType      @default(ADMISSION_FEE)
  status         InvoiceStatus    @default(PENDING)
  issuedAt       DateTime         @default(now())
  totalAmount    Decimal          @db.Decimal(12, 2)
  balanceDue     Decimal          @db.Decimal(12, 2)
  dueDate        DateTime?
  remarks        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?
  sourceNode     String?
  version        Int              @default(1)
  clinicId       String?
  clinic         Clinic?          @relation(fields: [clinicId], references: [id])
  issuedBy       User?            @relation("InvoiceIssuer", fields: [issuedById], references: [id])
  patient        Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments       Payment[]
  InsuranceClaim InsuranceClaim[]

  @@index([status])
  @@index([clinicId])
}

model Payment {
  id         String        @id @default(uuid())
  invoiceId  String
  paidById   String?
  amount     Decimal       @db.Decimal(12, 2)
  method     PaymentMethod
  paidAt     DateTime      @default(now())
  reference  String?
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?
  syncedAt   DateTime?
  sourceNode String?
  version    Int           @default(1)
  clinicId   String?
  clinic     Clinic?       @relation(fields: [clinicId], references: [id])
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paidBy     User?         @relation("PaymentPayer", fields: [paidById], references: [id])

  @@index([clinicId])
}

model Clinic {
  id               String             @id @default(uuid())
  name             String
  legalName        String?
  phone            String?
  email            String?
  address          String?
  city             String?
  country          String?
  status           String             @default("ACTIVE")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  users            User[]
  patients         Patient[]
  invoices         Invoice[]
  payments         Payment[]
  departments      Department[]
  serviceUnits     ServiceUnit[]
  pharmacies       Pharmacy[]
  medicationStocks MedicationStock[]
  services         Service[]
  PurchaseOrder    PurchaseOrder[]
  StockLot         StockLot[]
  StockTransaction StockTransaction[]
  Employee         Employee[]
}

model Supplier {
  id              String            @id @default(uuid())
  name            String
  phone           String?
  email           String?
  address         String?
  status          String            @default("ACTIVE")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  PurchaseOrder   PurchaseOrder[]
  GoodsReceipt    GoodsReceipt[]
  SupplierInvoice SupplierInvoice[]
  SupplierPayment SupplierPayment[]
}

model MedicationStock {
  id            String    @id @default(uuid())
  medicationId  String
  batchNumber   String?
  quantity      Int       @default(0)
  lowStockLevel Int       @default(10)
  criticalLevel Int       @default(3)
  purchasePrice Decimal?  @db.Decimal(12, 2)
  expiryDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  clinicId      String?

  clinic     Clinic?   @relation(fields: [clinicId], references: [id])
  Pharmacy   Pharmacy? @relation(fields: [pharmacyId], references: [id])
  pharmacyId String?

  @@index([medicationId])
  @@index([expiryDate])
  @@index([clinicId])
}

model StockMovement {
  id            String   @id @default(uuid())
  medicationId  String
  supplierId    String?
  type          String
  quantity      Int
  unitPrice     Decimal? @db.Decimal(12, 2)
  reason        String?
  reference     String?
  performedById String?
  createdAt     DateTime @default(now())
  clinicId      String?

  @@index([clinicId])
  @@index([medicationId, createdAt])
  @@index([supplierId])
}

model InvoiceLine {
  id          String    @id @default(uuid())
  invoiceId   String
  serviceId   String?
  label       String
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalAmount Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([invoiceId])
  @@index([serviceId])
}

model PaymentValidation {
  id          String    @id @default(uuid())
  paymentId   String?
  invoiceId   String?
  validatorId String?
  status      String    @default("PENDING")
  note        String?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([invoiceId, status])
  @@index([paymentId])
}

model CashRegister {
  id          String    @id @default(uuid())
  cashierId   String?
  label       String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  openingCash Decimal   @default(0) @db.Decimal(12, 2)
  closingCash Decimal?  @db.Decimal(12, 2)
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())

  @@index([cashierId, status])
}

model Expense {
  id        String    @id @default(uuid())
  category  String
  label     String
  amount    Decimal   @db.Decimal(12, 2)
  paidAt    DateTime  @default(now())
  paidById  String?
  note      String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([paidAt])
}

model Revenue {
  id         String   @id @default(uuid())
  source     String
  serviceId  String?
  invoiceId  String?
  paymentId  String?
  amount     Decimal  @db.Decimal(12, 2)
  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([receivedAt])
  @@index([serviceId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String
  userId     String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int       @default(1)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String               @id @default(uuid())
  patientId     String?
  recipientId   String?
  authorId      String?
  type          NotificationType     @default(ALERT)
  status        NotificationStatus   @default(UNREAD)
  priority      NotificationPriority @default(MEDIUM)
  title         String
  message       String
  relatedEntity String?
  relatedId     String?
  sendAt        DateTime?            @default(now())
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?
  syncedAt      DateTime?
  sourceNode    String?
  version       Int                  @default(1)
  author        User?                @relation("NotificationAuthor", fields: [authorId], references: [id])
  patient       Patient?             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recipient     User?                @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, status])
}

model ChatMessage {
  id            String        @id @default(uuid())
  senderId      String
  recipientId   String
  recipientType String        @default("USER")
  text          String
  status        MessageStatus @default(SENT)
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  sender        User          @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient     User          @relation("ChatMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, status])
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  patientId  String?
  action     AuditAction
  entity     String
  entityId   String
  summary    String
  metadata   Json?
  createdAt  DateTime    @default(now())
  syncedAt   DateTime?
  sourceNode String?
  version    Int         @default(1)
  actor      User?       @relation(fields: [actorId], references: [id])
  patient    Patient?    @relation(fields: [patientId], references: [id])

  @@index([actorId])
  @@index([patientId])
  @@index([entity, entityId])
}

model SyncEvent {
  id        String   @id @default(uuid())
  tableName String
  recordId  String
  operation String
  payload   Json
  synced    Boolean  @default(false)
  createdAt DateTime @default(now())
}

/// Shared enums for RBAC and workflows.
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoleSlug {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  NURSE
  PHYSICIAN
  LAB_TECHNICIAN
  LAB_MANAGER
  RADIOLOGIST
  SURGEON
  ANESTHESIOLOGIST
  PHARMACIST
  CASHIER
  PATIENT
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  APPROVE
  REVIEW
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ConsultationStatus {
  DRAFT
  IN_PROGRESS
  FINALIZED
  CANCELLED
}

enum HospitalizationStatus {
  ADMITTED
  TRANSFERRED
  DISCHARGED
