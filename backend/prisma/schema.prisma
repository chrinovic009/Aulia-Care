}

model LabRequestEvent {
  id               String   @id @default(uuid())
  labRequestId     String
  labRequestItemId String?
  action           String
  fromStatus       String?
  toStatus         String?
  performedById    String?
  note             String?
  createdAt        DateTime @default(now())

  labRequest     LabRequest      @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  labRequestItem LabRequestItem? @relation(fields: [labRequestItemId], references: [id])
  performedBy    User?           @relation("LabRequestEventPerformedBy", fields: [performedById], references: [id])

  @@index([labRequestId])
  @@index([labRequestItemId])
}

model LabResult {
  id                      String                    @id @default(uuid())
  labRequestId            String
  labRequestItemId        String?
  resultCode              String
  resultName              String
  resultType              LabResultType             @default(MULTI_PARAMETER)
  resultStatus            LabResultValidationStatus @default(PENDING)
  resultValue             String?
  numericValue            Decimal?                  @db.Decimal(12, 4)
  textValue               String?
  units                   String?
  referenceRange          String?
  interpretation          String?
  reportedById            String?
  technicalValidatedById  String?
  biologicalValidatedById String?
  reportedAt              DateTime                  @default(now())
  technicalValidationAt   DateTime?
  biologicalValidationAt  DateTime?
  comments                String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @default(now())
  deletedAt               DateTime?
  syncedAt                DateTime?
  sourceNode              String?
  version                 Int                       @default(1)

  labRequest            LabRequest           @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  labRequestItem        LabRequestItem?      @relation(fields: [labRequestItemId], references: [id], onDelete: Cascade)
  reportedBy            User?                @relation("LabResultReporter", fields: [reportedById], references: [id])
  technicalValidatedBy  User?                @relation("LabResultTechnicalValidator", fields: [technicalValidatedById], references: [id])
  biologicalValidatedBy User?                @relation("LabResultBiologicalValidator", fields: [biologicalValidatedById], references: [id])
  parameters            LabResultParameter[]

  @@index([resultCode])
  @@index([labRequestItemId])
}

model LabResultParameter {
  id                 String   @id @default(uuid())
  labResultId        String
  labTestParameterId String?
  valueNumeric       Decimal? @db.Decimal(12, 4)
  valueText          String?
  interpretation     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())

  labResult        LabResult         @relation(fields: [labResultId], references: [id], onDelete: Cascade)
  labTestParameter LabTestParameter? @relation(fields: [labTestParameterId], references: [id])

  @@index([labResultId])
  @@index([labTestParameterId])
}

model LabSection {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  categories LabCategory[]
  staff      LabSectionStaff[]
