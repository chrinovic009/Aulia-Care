  quantity        Decimal                      @db.Decimal(12, 2)
  unit            String
  reference       String?
  note            String?
  performedById   String?
  createdAt       DateTime                     @default(now())

  labConsumable LabConsumable @relation(fields: [labConsumableId], references: [id], onDelete: Cascade)
  performedBy   User?         @relation("LabConsumableTransactionPerformedBy", fields: [performedById], references: [id])

  @@index([labConsumableId])
}

model LabReport {
  id               String          @id @default(uuid())
  labRequestId     String
  labRequestItemId String?
  title            String
  status           LabReportStatus @default(DRAFT)
  summary          String?
  reportUrl        String?
  issuedById       String?
  generatedAt      DateTime?
  publishedAt      DateTime?
